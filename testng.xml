<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.9.dtd">
<suite name="Flipkart Test Suite" parallel="none">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.HomePageTest"/>
            <class name="tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.SearchPageTest"/>
            <class name="tests.ProductPageTest"/>
        </classes>
    </test>




</suite>
